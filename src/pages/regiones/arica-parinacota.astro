---
import ModernLayout from '../../layouts/ModernLayout.astro';
---

<ModernLayout title="Desarrollo Web Región de Arica y Parinacota | Digitaliza Todo">
  <div class="region-hero">
    <h1>DESARROLLO WEB EN <span class="region-name">ARICA Y PARINACOTA</span></h1>
    <p>🏖️ Atención presencial • Precios locales • Entrega rápida</p>
    <div class="cities-grid">
      <a href="/arica" class="city-card">
        <h3>ARICA</h3>
        <p>Ciudad principal</p>
        <span class="price">Desde $149.890</span>
      </a>
      <div class="city-card">
        <h3>PUTRE</h3>
        <p>Atención remota</p>
        <span class="price">Desde $149.890</span>
      </div>
    </div>
  </div>
</ModernLayout>

<style>
  .region-hero { min-height: 100vh; background: #00FF7F; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; }
  .region-hero h1 { font-size: clamp(2rem, 6vw, 4rem); font-weight: 900; color: #000; margin-bottom: 1rem; }
  .region-name { background: #FFD700; color: #000; padding: 0.2em 0.5em; border: 4px solid #000; }
  .cities-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem; max-width: 800px; }
  .city-card { background: white; border: 4px solid #000; padding: 2rem; text-decoration: none; color: #000; transition: all 0.3s ease; }
  .city-card:hover { transform: translateY(-5px); box-shadow: 8px 8px 0 #000; }
  .city-card h3 { font-size: 1.5rem; font-weight: 900; margin-bottom: 0.5rem; }
  .price { background: #FF1493; color: white; padding: 0.5rem 1rem; font-weight: 900; }
</style>