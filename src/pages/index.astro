// Dot grid gravity effect
const canvas=document.getElementById('dotGrid');
const ctx=canvas.getContext('2d');
let w,h,dots=[],mouse={x:null,y:null};

function resize(){
const hero=document.getElementById('hero');
w=canvas.width=window.innerWidth;
h=canvas.height=hero?hero.offsetHeight:window.innerHeight;
dots=[];
for(let x=0;x<w;x+=30){
for(let y=0;y<h;y+=30){
dots.push({x,y,ox:x,oy:y});
}
}
}

function draw(){
const isDark=document.documentElement.classList.contains('dark');
const baseColor=isDark?'#475569':'#cbd5e1';
const midColor=isDark?'#8b5cf6':'#a78bfa';
const hoverColor=isDark?'#ec4899':'#f9a8d4';
ctx.clearRect(0,0,w,h);
dots.forEach(d=>{let dx=d.x-mouse.x,dy=d.y-mouse.y,dist=Math.sqrt(dx*dx+dy*dy),intensity=Math.max(0,400-dist)/400;let radius=1.5+intensity*1.5;let color;if(intensity>0.5){const t=(intensity-0.5)/0.5;const r1=parseInt(midColor.slice(1,3),16),g1=parseInt(midColor.slice(3,5),16),b1=parseInt(midColor.slice(5,7),16),r2=parseInt(hoverColor.slice(1,3),16),g2=parseInt(hoverColor.slice(3,5),16),b2=parseInt(hoverColor.slice(5,7),16);color=`rgb(${Math.round(r1+(r2-r1)*t)},${Math.round(g1+(g2-g1)*t)},${Math.round(b1+(b2-b1)*t)})`;}else{const t=intensity/0.5;const r1=parseInt(baseColor.slice(1,3),16),g1=parseInt(baseColor.slice(3,5),16),b1=parseInt(baseColor.slice(5,7),16),r2=parseInt(midColor.slice(1,3),16),g2=parseInt(midColor.slice(3,5),16),b2=parseInt(midColor.slice(5,7),16);color=`rgb(${Math.round(r1+(r2-r1)*t)},${Math.round(g1+(g2-g1)*t)},${Math.round(b1+(b2-b1)*t)})`;}ctx.fillStyle=color;ctx.beginPath();ctx.arc(d.x,d.y,radius,0,Math.PI*2);ctx.fill();});
requestAnimationFrame(draw);
}

window.addEventListener('resize',resize);
document.addEventListener('mousemove',e=>{mouse.x=e.clientX+window.pageXOffset;mouse.y=e.clientY+window.pageYOffset;});
resize();
draw();

// Header scroll animation
let lastScroll=0;
window.addEventListener('scroll',()=>{
const scroll=window.pageYOffset;
const headerWrapper=document.getElementById('headerWrapper');
if(scroll>100&&scroll>lastScroll){
headerWrapper.style.transform='translateY(-100px)';
}else{
headerWrapper.style.transform='translateY(0)';
}
lastScroll=scroll;

// Cerrar menú móvil al hacer scroll
const menu=document.getElementById('mobileMenu');
const icon=document.getElementById('menuIcon');
if(!menu.classList.contains('hidden')){
menu.style.opacity='0';
menu.style.transform='translateY(-10px)';
setTimeout(()=>{
menu.classList.add('hidden');
menu.style.opacity='';
menu.style.transform='';
icon.setAttribute('d','M4 6h16M4 12h16M4 18h16');
},200);
}
});

// 3D effect for about card
const aboutCard=document.getElementById('aboutCard');
const aboutSection=document.getElementById('nosotros');
if(aboutCard&&aboutSection){
let currentX=0,currentY=0,targetX=0,targetY=0;
aboutSection.addEventListener('mousemove',e=>{
const rect=aboutCard.getBoundingClientRect();
const x=e.clientX-rect.left;
const y=e.clientY-rect.top;
const centerX=rect.width/2;
const centerY=rect.height/2;
targetX=((y-centerY)/centerY)*5;
targetY=((x-centerX)/centerX)*5;
});
aboutSection.addEventListener('mouseleave',()=>{
targetX=0;
targetY=0;
});
function animate3D(){
currentX+=(targetX-currentX)*0.1;
currentY+=(targetY-currentY)*0.1;
aboutCard.style.transform=`perspective(1000px) rotateX(${-currentX}deg) rotateY(${currentY}deg)`;
requestAnimationFrame(animate3D);
}
animate3D();
}
