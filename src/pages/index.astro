<script src="https://unpkg.com/lucide@latest"></script>
<script>
setTimeout(() => {
// @ts-ignore
if(typeof lucide !== 'undefined') lucide.createIcons();
}, 100);

// Workflow timeline animation
const workflowObserver = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
const steps = document.querySelectorAll('.workflow-step');
const timelineLine = document.getElementById('timeline-line');

steps.forEach((step, index) => {
setTimeout(() => {
step.classList.remove('opacity-0', 'translate-y-4');
step.classList.add('opacity-100', 'translate-y-0');
}, index * 200);
});

if (timelineLine) {
setTimeout(() => {
timelineLine.style.width = '100%';
}, 100);
}

workflowObserver.unobserve(entry.target);
}
});
}, { threshold: 0.2 });

const workflowSection = document.getElementById('workflow');
if (workflowSection) workflowObserver.observe(workflowSection);
</script>

