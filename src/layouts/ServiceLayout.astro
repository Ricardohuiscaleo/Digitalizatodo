---
import '../styles/global.css';
import '../styles/dark-mode.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>{title} | Digitaliza Todo</title>
<meta name="description" content={description}/>
<link rel="icon" href="/DLogo-v2.png"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
</head>
<body class="font-sans text-slate-600 dark:text-slate-300 min-h-screen selection:bg-indigo-100 selection:text-indigo-900 dark:selection:bg-indigo-900 dark:selection:text-indigo-100 bg-[#fafafa] dark:bg-slate-900 transition-colors relative">

<canvas id="dotGrid" class="fixed inset-0 pointer-events-none"></canvas>

<div class="fixed top-6 left-0 w-full z-50 px-4 md:px-6 transition-all duration-500" id="headerWrapper">
<header class="mx-auto bg-white/90 dark:bg-slate-800/90 backdrop-blur-md border border-slate-200 dark:border-slate-700 rounded-2xl shadow-sm h-16 px-6 flex items-center justify-between overflow-hidden transition-all duration-500" id="headerMain" style="max-width:80rem">
<a href="/" class="flex items-center gap-2 cursor-pointer">
<img src="/DLogo-v2.png" alt="D" class="w-8 h-8 rounded-lg transform -rotate-3"/>
<span class="font-bold text-slate-800 dark:text-slate-100 tracking-tight">Digitaliza<span class="font-normal text-slate-400 dark:text-slate-500">Todo</span></span>
</a>
<nav class="hidden md:flex items-center gap-1 transition-all duration-500" id="headerNav">
<a href="/#servicios" class="px-4 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all">Servicios</a>
<a href="/#proyectos" class="px-4 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all">Proyectos</a>
<a href="/#nosotros" class="px-4 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all">Nosotros</a>
<div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-2"></div>
<button onclick="toggleDark()" class="w-10 h-10 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all">
<i data-lucide="sun" class="w-5 h-5 dark:hidden"></i>
<i data-lucide="moon" class="w-5 h-5 hidden dark:block"></i>
</button>
<a href="/#contacto" class="bg-slate-900 dark:bg-indigo-600 text-white px-5 py-2 text-sm font-medium rounded-lg hover:bg-indigo-600 dark:hover:bg-indigo-500 transition-colors shadow-lg shadow-indigo-200 dark:shadow-indigo-900/50">Hablemos</a>
</nav>
<div class="md:hidden flex items-center gap-2 transition-all duration-500" id="headerMobile">
<a href="/#contacto" class="bg-slate-900 dark:bg-indigo-600 text-white px-4 py-2 text-sm font-medium rounded-lg hover:bg-indigo-600 dark:hover:bg-indigo-500 transition-colors">Hablemos</a>
<button onclick="toggleMenu()" class="w-10 h-10 flex items-center justify-center" id="menuBtn">
<svg class="w-6 h-6 text-slate-700 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path id="menuIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
</svg>
</button>
</div>
</header>
</div>

<div id="mobileMenu" class="fixed top-24 right-4 left-4 md:left-auto md:w-64 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md border border-slate-200 dark:border-slate-700 rounded-2xl shadow-xl p-4 z-40 hidden">
<nav class="flex flex-col gap-2">
<a href="/#servicios" onclick="toggleMenu()" class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all text-left">Servicios</a>
<a href="/#proyectos" onclick="toggleMenu()" class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all text-left">Proyectos</a>
<a href="/#nosotros" onclick="toggleMenu()" class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-all text-left">Nosotros</a>
<div class="h-px bg-slate-200 dark:bg-slate-700 my-1"></div>
<a href="/#contacto" onclick="toggleMenu()" class="bg-slate-900 dark:bg-indigo-600 text-white px-4 py-2 text-sm font-medium rounded-lg hover:bg-indigo-600 dark:hover:bg-indigo-500 transition-colors">Hablemos</a>
</nav>
</div>

<main class="relative z-10">
<slot />
</main>

<footer class="py-12 px-6 dark:bg-slate-900 relative z-10 border-t border-slate-200 dark:border-slate-700">
<div class="max-w-6xl mx-auto">
<div class="flex justify-center gap-8 opacity-60 hover:opacity-100 transition-opacity mb-6">
<a href="https://www.linkedin.com/in/rhuiscaleo/" target="_blank"><i data-lucide="linkedin" class="w-6 h-6 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"></i></a>
<a href="https://wa.me/56945392581" target="_blank"><i data-lucide="message-circle" class="w-6 h-6 cursor-pointer hover:text-green-600 dark:hover:text-green-400 transition-colors"></i></a>
<a href="mailto:info@digitalizatodo.cl"><i data-lucide="mail" class="w-6 h-6 cursor-pointer hover:text-blue-600 dark:hover:text-blue-400 transition-colors"></i></a>
</div>
<div class="text-center text-xs font-mono text-slate-400 dark:text-slate-500">© 2024 DIGITALIZA TODO SPA • RM, CHILE</div>
</div>
</footer>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
setTimeout(() => {
// @ts-ignore
if(typeof lucide !== 'undefined') lucide.createIcons();
}, 100);
</script>

<script is:inline>
if(localStorage.theme==='dark')document.documentElement.classList.add('dark');
function toggleDark(){
if(document.documentElement.classList.contains('dark')){
document.documentElement.classList.remove('dark');
localStorage.theme='light';
}else{
document.documentElement.classList.add('dark');
localStorage.theme='dark';
}
setTimeout(()=>{if(typeof lucide!=='undefined')lucide.createIcons();},50);
}
function toggleMenu(){
const menu=document.getElementById('mobileMenu');
const icon=document.getElementById('menuIcon');
if(menu.classList.contains('hidden')){
menu.classList.remove('hidden');
icon.setAttribute('d','M6 18L18 6M6 6l12 12');
}else{
menu.classList.add('hidden');
icon.setAttribute('d','M4 6h16M4 12h16M4 18h16');
}
}

// Dot grid effect
const canvas=document.getElementById('dotGrid');
const ctx=canvas.getContext('2d');
let w,h,dots=[],mouse={x:null,y:null};

function resize(){
w=canvas.width=window.innerWidth;
h=canvas.height=window.innerHeight;
dots=[];
for(let x=0;x<w;x+=20){
for(let y=0;y<h;y+=20){
dots.push({x,y,ox:x,oy:y});
}
}
}

function draw(){
const isDark=document.documentElement.classList.contains('dark');
const baseColor=isDark?'#475569':'#cbd5e1';
const midColor=isDark?'#8b5cf6':'#a78bfa';
const hoverColor=isDark?'#ec4899':'#f9a8d4';
ctx.clearRect(0,0,w,h);
dots.forEach(d=>{let dx=d.x-mouse.x,dy=d.y-mouse.y,dist=Math.sqrt(dx*dx+dy*dy),intensity=Math.max(0,500-dist)/500;let color;if(intensity>0.5){const t=(intensity-0.5)/0.5;const r1=parseInt(midColor.slice(1,3),16),g1=parseInt(midColor.slice(3,5),16),b1=parseInt(midColor.slice(5,7),16),r2=parseInt(hoverColor.slice(1,3),16),g2=parseInt(hoverColor.slice(3,5),16),b2=parseInt(hoverColor.slice(5,7),16);color=`rgb(${Math.round(r1+(r2-r1)*t)},${Math.round(g1+(g2-g1)*t)},${Math.round(b1+(b2-b1)*t)})`;}else{const t=intensity/0.5;const r1=parseInt(baseColor.slice(1,3),16),g1=parseInt(baseColor.slice(3,5),16),b1=parseInt(baseColor.slice(5,7),16),r2=parseInt(midColor.slice(1,3),16),g2=parseInt(midColor.slice(3,5),16),b2=parseInt(midColor.slice(5,7),16);color=`rgb(${Math.round(r1+(r2-r1)*t)},${Math.round(g1+(g2-g1)*t)},${Math.round(b1+(b2-b1)*t)})`;}ctx.fillStyle=color;ctx.beginPath();ctx.arc(d.x,d.y,1,0,Math.PI*2);ctx.fill();});
requestAnimationFrame(draw);
}

window.addEventListener('resize',resize);
document.addEventListener('mousemove',e=>{mouse.x=e.clientX;mouse.y=e.clientY;});
resize();
draw();

// Header scroll animation
let lastScroll=0;
window.addEventListener('scroll',()=>{
const scroll=window.pageYOffset;
const headerWrapper=document.getElementById('headerWrapper');
if(scroll>100&&scroll>lastScroll){
headerWrapper.style.transform='translateY(-100px)';
}else{
headerWrapper.style.transform='translateY(0)';
}
lastScroll=scroll;
});
</script>

</body>
</html>
