---
import ModernLayout from '../layouts/ModernLayout.astro';
---

<ModernLayout title="Digitaliza Todo | Hero">
  <!-- Header with Logo -->
  <header class="header" id="header">
    <a href="#hero">
      <img src="/DLogo-v2.png" alt="Digitaliza Todo" class="logo" width="60" height="60" fetchpriority="high">
    </a>
  </header>

  <!-- Dot Navigation Desktop -->
  <nav class="dot-nav">
    <a href="#hero" class="dot-link active" data-section="hero"><span class="dot-label">Inicio</span></a>
    <a href="#services" class="dot-link" data-section="services"><span class="dot-label">Servicios</span></a>
    <a href="#projects" class="dot-link" data-section="projects"><span class="dot-label">Proyectos</span></a>
    <a href="#company" class="dot-link" data-section="company"><span class="dot-label">Nosotros</span></a>
    <a href="#contact" class="dot-link" data-section="contact"><span class="dot-label">Contacto</span></a>
  </nav>

  <!-- Bottom Tab Bar Mobile -->
  <nav class="bottom-nav">
    <a href="#hero" class="bottom-link active" data-section="hero">
      <i data-lucide="home"></i>
      <span>Inicio</span>
    </a>
    <a href="#services" class="bottom-link" data-section="services">
      <i data-lucide="briefcase"></i>
      <span>Servicios</span>
    </a>
    <a href="#projects" class="bottom-link" data-section="projects">
      <i data-lucide="folder"></i>
      <span>Proyectos</span>
    </a>
    <a href="#company" class="bottom-link" data-section="company">
      <i data-lucide="building-2"></i>
      <span>Nosotros</span>
    </a>
    <a href="#contact" class="bottom-link" data-section="contact">
      <i data-lucide="message-circle"></i>
      <span>Contacto</span>
    </a>
  </nav>

  <main role="main">
  <section class="hero" id="hero" aria-label="Inicio">
    <div class="hero-content">
      <h1>Digitaliza<span>Todo</span></h1>
      <p style="font-family:system-ui,-apple-system,BlinkMacSystemFont,sans-serif;font-size:1rem;color:#000;font-weight:700;text-transform:uppercase;margin-bottom:2rem;text-rendering:optimizeSpeed">Creamos <span class="arrow">►</span> Soluciones Digitales</p>
      <div class="buttons">
        <button class="btn-primary" onclick="document.getElementById('services').scrollIntoView({behavior:'smooth'})" aria-label="Ver servicios disponibles">Ver Servicios</button>
        <button class="btn-secondary" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Contactar</button>
      </div>
    </div>
  </section>

  <aside class="stats-ribbon" aria-label="Estadísticas">
    <div class="ribbon-scroll">
      <div class="ribbon-track">
        <span class="story-text">💰 $457M en ahorros generados • ⚡ +5.000 APIs desarrolladas • 🚀 +50 proyectos completados • 💻 Digitalizando negocios • 🎯 Soluciones escalables • </span>
        <span class="story-text">💰 $457M en ahorros generados • ⚡ +5.000 APIs desarrolladas • 🚀 +50 proyectos completados • 💻 Digitalizando negocios • 🎯 Soluciones escalables • </span>
      </div>
    </div>
  </aside>

  <section class="services" id="services" aria-label="Servicios">
    <div class="services-content">
      <h2>SERVICIOS QUE <span class="highlight-black">RESUELVEN ❤️</span></h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            <h3>Apps Web</h3>
          </div>
          <div class="service-info">
            <p>E-commerce y aplicaciones escalables con React/Vue/Angular. <a href="/servicios/apps-web" class="more-info" aria-label="Ver más información sobre Apps Web">Más información sobre Apps Web</a></p>
            <div class="service-price">$449.890</div>
            <button class="service-btn" onclick="openQuoteModalModern('Apps Web', '$449.890')">Cotizar</button>
          </div>
        </div>
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            <h3>Páginas Web</h3>
          </div>
          <div class="service-info">
            <p>Sitios profesionales orientados al negocio con SEO optimizado. <a href="/servicios/paginas-web" class="more-info" aria-label="Ver más información sobre Páginas Web">Más información sobre Páginas Web</a></p>
            <div class="service-price">$149.890</div>
            <button class="service-btn" onclick="openQuoteModalModern('Páginas Web', '$149.890')">Cotizar</button>
          </div>
        </div>
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
            <h3>Marketing Digital</h3>
          </div>
          <div class="service-info">
            <p>Estrategias escalables para vender más. <a href="/servicios/marketing-digital" class="more-info" aria-label="Ver más información sobre Marketing Digital">Más información sobre Marketing Digital</a></p>
            <div class="service-price">$30.000/h</div>
            <button class="service-btn" onclick="openQuoteModalModern('Marketing Digital', '$30.000/h')">Cotizar</button>
          </div>
        </div>
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
            <h3>Contenido RSS</h3>
          </div>
          <div class="service-info">
            <p>Contenido gráfico, videos promocionales y fotografía. <a href="/servicios/contenido-rss" class="more-info" aria-label="Ver más información sobre Contenido RSS">Más información sobre Contenido RSS</a></p>
            <div class="service-price">$19.890</div>
            <button class="service-btn" onclick="openQuoteModalModern('Contenido RSS', '$19.890')">Cotizar</button>
          </div>
        </div>
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1.06 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1.06H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1.06-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1.06 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1.06H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1.06z"/></svg>
            <h3>Soluciones Digitales</h3>
          </div>
          <div class="service-info">
            <p>Automatización empresarial y sistemas de gestión. <a href="/servicios/soluciones-digitales" class="more-info" aria-label="Ver más información sobre Soluciones Digitales">Más información sobre Soluciones Digitales</a></p>
            <div class="service-price">$124.890/mes</div>
            <button class="service-btn" onclick="openQuoteModalModern('Soluciones Digitales', '$124.890/mes')">Cotizar</button>
          </div>
        </div>
        <div class="service-card">
          <div class="service-header">
            <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
            <h3>Software a Medida</h3>
          </div>
          <div class="service-info">
            <p>Desarrollo personalizado con arquitectura escalable. <a href="/servicios/software-a-medida" class="more-info" aria-label="Ver más información sobre Software a Medida">Más información sobre Software a Medida</a></p>
            <div class="service-price">$124.890/mes</div>
            <button class="service-btn" onclick="openQuoteModalModern('Software a Medida', '$124.890/mes')">Cotizar</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="projects" id="projects" aria-label="Proyectos">
    <div class="projects-content">
      <h2>Últimos Proyectos Entregados</h2>
      <p class="projects-subtitle">Soluciones digitales que <span class="highlight-yellow">transforman negocios</span></p>
      <div class="projects-grid">
        <a href="https://patriciosepulveda.cl" target="_blank" class="project-card">
          <img src="/proyectos/patriciosepulveda.cl.png" alt="Estudio Jurídico" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>Estudio Jurídico</h3>
            <p class="project-client">Patricio Sepúlveda</p>
            <p class="project-desc">Sitio web profesional para estudio jurídico en Arica con SEO optimizado y sistema de consultas</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
              <span class="tag">SEO</span>
              <span class="tag">PHP</span>
            </div>
          </div>
        </a>
        <a href="https://app.laruta11.cl" target="_blank" class="project-card">
          <img src="/proyectos/app.laruta11.cl.png" alt="La Ruta 11" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>La Ruta 11</h3>
            <p class="project-client">Carta y Punto de Venta</p>
            <p class="project-desc">Sistema completo: Menú PWA, panel admin, analytics, inventarios, plan de compras y control de ventas</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
              <span class="tag">PWA</span>
              <span class="tag">PHP</span>
            </div>
          </div>
        </a>
        <a href="https://agenterag.com" target="_blank" class="project-card">
          <img src="/proyectos/agenterag.com.png" alt="Agente RAG" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>Agente RAG</h3>
            <p class="project-client">Soluciones IA</p>
            <p class="project-desc">Plataforma de Inteligencia Artificial con RAG, automatización empresarial y generación de contenido</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
              <span class="tag">IA RAG</span>
              <span class="tag">Python</span>
            </div>
          </div>
        </a>
        <a href="https://demo.automotora.online" target="_blank" class="project-card">
          <img src="/proyectos/demo.automotora.online.png" alt="Automotora Demo" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>Automotora Demo</h3>
            <p class="project-client">Venta de Vehículos</p>
            <p class="project-desc">Plataforma web para automotora en Arica con catálogo de vehículos, filtros avanzados y sistema de contacto</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
              <span class="tag">PWA</span>
              <span class="tag">WhatsApp</span>
            </div>
          </div>
        </a>
        <a href="https://colegio.agenterag.com" target="_blank" class="project-card">
          <img src="/proyectos/colegio.agenterag.com.png" alt="Colegio" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>Colegio</h3>
            <p class="project-client">Portal Apoderados</p>
            <p class="project-desc">Sistema de gestión educativa con portal para apoderados, notas, asistencia, mensajería y eventos</p>
            <div class="project-tags">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">MySQL</span>
              <span class="tag">PWA</span>
              <span class="tag">Dashboard</span>
            </div>
          </div>
        </a>
        <a href="https://matemagica.agenterag.com" target="_blank" class="project-card">
          <img src="/proyectos/matemagica.agenterag.com.png" alt="Matemágica" class="project-img" width="400" height="250" loading="lazy">
          <div class="project-info">
            <h3>Matemágica</h3>
            <p class="project-client">Plataforma Educativa</p>
            <p class="project-desc">PWA educativa con IA integrada, 8 módulos matemáticos CPS, dashboard apoderados, gestión perfiles, seguimiento progreso, PDF reportes y juegos</p>
            <div class="project-tags">
              <span class="tag">PWA</span>
              <span class="tag">IA Integrada</span>
              <span class="tag">Supabase</span>
              <span class="tag">Tailwind</span>
              <span class="tag">JavaScript</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="company" id="company" aria-label="Nosotros">
    <div class="company-content">
      <h2>¿QUIÉNES SOMOS?</h2>
      
      <div class="company-text">
        <p class="company-desc">Somos una empresa chilena especializada en desarrollo de software, automatización con IA y soluciones digitales a medida. Liderados por Ricardo Huiscaleo, Ingeniero de Control de Gestión y Full Stack Developer con certificación Lean Six Sigma Black Belt.</p>
        
        <div class="company-stats">
          <div class="stat"><span class="stat-number">+14</span> años experiencia</div>
          <div class="stat"><span class="stat-number">+50</span> proyectos</div>
          <div class="stat"><span class="stat-number">$457M</span> ahorros generados</div>
        </div>

        <div class="mission-vision">
          <div class="mv-mini">
            <div class="code-header">mision.json</div>
            <div class="code-content" id="mision-code"></div>
          </div>
          <div class="mv-mini">
            <div class="code-header">vision.json</div>
            <div class="code-content" id="vision-code"></div>
          </div>
        </div>

        <script>
          // Header hide/show on scroll
          let lastScroll = 0;
          const header = document.getElementById('header');
          
          window.addEventListener('scroll', () => {
            const currentScroll = window.scrollY;
            if (currentScroll <= 0) {
              header?.classList.remove('hidden');
            } else if (currentScroll > lastScroll) {
              header?.classList.add('hidden');
            } else {
              header?.classList.remove('hidden');
            }
            lastScroll = currentScroll;
          });

          // Navigation functionality
          document.addEventListener('DOMContentLoaded', () => {
            const dotLinks = document.querySelectorAll('.dot-link');
            const bottomLinks = document.querySelectorAll('.bottom-link');
            const sections = document.querySelectorAll('[id]');

            // Smooth scroll
            [...dotLinks, ...bottomLinks].forEach(link => {
              link.addEventListener('click', (e) => {
                e.preventDefault();
                const href = link.getAttribute('href');
                if (href) {
                  const targetId = href.substring(1);
                  const targetSection = document.getElementById(targetId);
                  if (targetSection) {
                    targetSection.scrollIntoView({ behavior: 'smooth' });
                  }
                }
              });
            });

            // Update active state on scroll
            let currentActive = 'hero';
            
            function updateActiveSection() {
              const scrollPos = window.scrollY + window.innerHeight / 2;
              const isBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 100;
              
              let newActive = currentActive;
              
              if (isBottom) {
                newActive = 'contact';
              } else {
                sections.forEach(section => {
                  const sectionTop = (section as HTMLElement).offsetTop;
                  const sectionHeight = (section as HTMLElement).offsetHeight;
                  const sectionId = section.id;
                  
                  if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
                    newActive = sectionId;
                  }
                });
              }
              
              if (newActive !== currentActive) {
                currentActive = newActive;
                dotLinks.forEach(link => link.classList.remove('active'));
                bottomLinks.forEach(link => link.classList.remove('active'));
                document.querySelector(`.dot-link[data-section="${currentActive}"]`)?.classList.add('active');
                document.querySelector(`.bottom-link[data-section="${currentActive}"]`)?.classList.add('active');
              }
            }

            window.addEventListener('scroll', updateActiveSection);
            updateActiveSection();
            updateActiveSection();
          });

          const isDesktop = window.innerWidth >= 1024;
          const fontSize = isDesktop ? '0.9rem' : '0.7rem';
          const lineHeight = isDesktop ? '1.6' : '1.4';
          const padding = isDesktop ? '0.8rem' : '0.5rem';
          
          const misionEl = document.getElementById('mision-code');
          if (misionEl) {
            misionEl.innerHTML = `
<div style="display:flex;font-size:${fontSize};font-family:'Courier New',monospace;line-height:${lineHeight}">
  <div style="color:#858585;padding-right:${padding};text-align:right;user-select:none;border-right:1px solid #3e3e3e;margin-right:${padding}">1<br>2<br>3<br>4<br>5<br>6</div>
  <pre style="margin:0;padding:0"><span style="color:#FFD700">{</span>
  <span style="color:#9cdcfe">"mision"</span><span style="color:#d4d4d4">:</span> <span style="color:#FFD700">{</span>
    <span style="color:#9cdcfe">"objetivo"</span><span style="color:#d4d4d4">:</span> <span style="color:#ce9178">"Crear soluciones digitales"</span><span style="color:#d4d4d4">,</span>
    <span style="color:#9cdcfe">"compromiso"</span><span style="color:#d4d4d4">:</span> <span style="color:#ce9178">"Resultados medibles y escalables"</span>
  <span style="color:#FFD700">}</span>
<span style="color:#FFD700">}</span></pre>
</div>`;
          }
          
          const visionEl = document.getElementById('vision-code');
          if (visionEl) {
            visionEl.innerHTML = `
<div style="display:flex;font-size:${fontSize};font-family:'Courier New',monospace;line-height:${lineHeight}">
  <div style="color:#858585;padding-right:${padding};text-align:right;user-select:none;border-right:1px solid #3e3e3e;margin-right:${padding}">1<br>2<br>3<br>4<br>5<br>6</div>
  <pre style="margin:0;padding:0"><span style="color:#FFD700">{</span>
  <span style="color:#9cdcfe">"vision"</span><span style="color:#d4d4d4">:</span> <span style="color:#FFD700">{</span>
    <span style="color:#9cdcfe">"futuro"</span><span style="color:#d4d4d4">:</span> <span style="color:#ce9178">"Referentes en transformación digital"</span><span style="color:#d4d4d4">,</span>
    <span style="color:#9cdcfe">"innovacion"</span><span style="color:#d4d4d4">:</span> <span style="color:#ce9178">"Soluciones digitales para tod@s"</span>
  <span style="color:#FFD700">}</span>
<span style="color:#FFD700">}</span></pre>
</div>`;
          }
        </script>

        <p class="company-legal">Soluciones en Inteligencia Artificial SPA • RUT: 78.109.539-7<br>📍 Av. Santa Magdalena 75, Oficina 304, Providencia, RM, Chile</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact" id="contact" aria-label="Contacto">
    <div class="contact-content">
      <h2>CONTACTO</h2>
      <p class="contact-subtitle">¿LISTO PARA DIGITALIZAR TU NEGOCIO? <span class="highlight-pink">HABLEMOS</span></p>
      
      <form id="contactForm" class="contact-form">
        <input type="text" id="contactName" placeholder="Tu nombre" required>
        <textarea id="contactMessage" placeholder="Describe tu proyecto" rows="3" required></textarea>
        <button type="button" class="btn-send" onclick="showContactModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          Enviar
        </button>
      </form>

      <div class="linkedin-section">
        <span class="linkedin-text">Conectemos <span class="emoji">:)</span></span>
        <a href="https://www.linkedin.com/in/rhuiscaleo/" target="_blank" class="linkedin-btn" aria-label="Conectar en LinkedIn con Ricardo Huiscaleo">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
        </a>
      </div>
    </div>
  </section>

  </main>

  <!-- Contact Modal -->
  <div class="contact-modal" id="contactModal">
    <div class="modal-content">
      <button class="modal-close" onclick="closeContactModal()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <div class="modal-body" id="modalBody"></div>
    </div>
  </div>

  <!-- Quote Modal -->
  <div class="contact-modal" id="quoteModal">
    <div class="modal-content">
      <button class="modal-close" onclick="closeQuoteModalModern()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <div class="modal-body" id="quoteModalBody"></div>
    </div>
  </div>

  <script>
    declare global {
      interface Window {
