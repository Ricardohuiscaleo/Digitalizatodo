---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" translate="no" class="notranslate">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/DLogo.png" sizes="64x64" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://unpkg.com" />
  <title>{title}</title>
  
  <meta name="theme-color" content="#00FF7F" />
  <meta name="description" content="Digitaliza Todo - Desarrollo de software, páginas web desde $149.890, apps web, marketing digital y soluciones con IA en Chile. +50 proyectos, $457M en ahorros generados." />
  <meta name="keywords" content="desarrollo software chile, páginas web chile, marketing digital, apps web, soluciones digitales, automatización IA, desarrollo a medida, e-commerce chile, SEO chile, desarrollo web arica, páginas web arica, marketing digital arica, diseño web arica, tiendas online arica" />
  <meta name="author" content="Digitaliza Todo - Soluciones en Inteligencia Artificial SPA" />
  <meta name="robots" content="index, follow" />
  <meta name="google" content="notranslate" />
  <link rel="canonical" href="https://digitalizatodo.cl" />
  
  <!-- Open Graph -->
  <meta property="og:site_name" content="Digitaliza Todo" />
  <meta property="og:title" content="Digitaliza Todo | Desarrollo de Software y Marketing Digital en Chile" />
  <meta property="og:description" content="Páginas web desde $149.890, apps web, marketing digital y soluciones con IA. +50 proyectos completados, $457M en ahorros generados." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://digitalizatodo.cl" />
  <meta property="og:image" content="https://digitalizatodo.cl/DLogo.png" />
  <meta property="og:locale" content="es_CL" />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Digitaliza Todo | Desarrollo de Software y Marketing Digital en Chile" />
  <meta name="twitter:description" content="Páginas web desde $149.890, apps web, marketing digital y soluciones con IA. +50 proyectos completados." />
  <meta name="twitter:image" content="https://digitalizatodo.cl/DLogo.png" />
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" /></noscript>
  
  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Digitaliza Todo",
    "legalName": "Soluciones en Inteligencia Artificial SPA",
    "url": "https://digitalizatodo.cl",
    "logo": "https://digitalizatodo.cl/DLogo.png",
    "description": "Desarrollo de software, páginas web, apps web, marketing digital y soluciones con IA en Chile. +50 proyectos completados, $457M en ahorros generados.",
    "foundingDate": "2024",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av. Santa Magdalena 75, Oficina 304",
      "addressLocality": "Providencia",
      "addressRegion": "Región Metropolitana",
      "addressCountry": "CL"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+56945392581",
      "contactType": "customer service",
      "email": "info@digitalizatodo.cl",
      "availableLanguage": "Spanish"
    },
    "sameAs": [
      "https://www.linkedin.com/in/rhuiscaleo/"
    ],
    "priceRange": "$$",
    "areaServed": "CL"
  }
  </script>
  
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Digitaliza Todo",
    "url": "https://digitalizatodo.cl",
    "description": "Desarrollo de software, páginas web y marketing digital en Chile",
    "inLanguage": "es-CL"
  }
  </script>
  <style>
    /* Critical CSS - Ultra Optimized */
    *{margin:0;padding:0;box-sizing:border-box}
    html,body{width:100%;background:#00FF7F;font:400 16px system-ui,-apple-system,sans-serif}
    .hero{height:100vh;background:#00FF7F;display:flex;align-items:center;justify-content:center;text-align:center;contain:layout style paint;content-visibility:auto}
    h1{font-size:2.2rem;font-weight:900;text-transform:uppercase;letter-spacing:.02em;margin:0 0 1rem;color:#000;line-height:1.2}
    h1 span{background:#fff;color:#000;padding:.2em .5em;border-radius:15px;border:4px solid #000;box-shadow:4px 4px 0 #FF1493;display:inline-block;transform:rotate(3deg);will-change:transform}
    .header{position:fixed;top:.5rem;left:1rem;z-index:999;will-change:transform}
    .logo{height:45px;width:auto;content-visibility:auto}
    .hero-content{position:relative;z-index:2}
    .hero p{font-size:1rem;color:#000;font-weight:700;text-transform:uppercase;margin:0 0 2rem}
    .arrow{color:#FFD700;font-size:1.3rem;font-weight:900;margin:0 .5rem;text-shadow:2px 2px 0 #000;display:inline-block}
    .buttons{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .btn-primary,.btn-secondary{padding:.9rem 1.5rem;font-size:.9rem;font-weight:900;text-transform:uppercase;border:3px solid #000;cursor:pointer;transform:skew(-10deg);transition:none}
    .btn-primary{background:#000;color:#00FF7F;box-shadow:4px 4px 0 #FF1493}
    .btn-secondary{background:#00BFFF;color:#000;box-shadow:4px 4px 0 #000}
    @media(min-width:768px){h1{font-size:clamp(2.2rem,7vw,4rem);letter-spacing:.05em}.hero p{font-size:clamp(1rem,3vw,1.5rem)}.arrow{font-size:1.5rem}.btn-primary,.btn-secondary{padding:1rem 2rem;font-size:1rem}.header{top:1rem;left:2rem}.logo{height:60px}}
  </style>
</head>

<body>
  <slot />
  
  <script>
    // Analytics disabled - enable when endpoint is ready
    // (window as any).dtAnalytics = { trackEvent: function() {} };
  </script>

  <!-- Preload critical resources -->
  <link rel="preload" as="image" href="/DLogo.png" fetchpriority="high" />
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof (window as any).lucide !== 'undefined') {
        (window as any).lucide.createIcons();
      }
    });
  </script>
</body>
</html>